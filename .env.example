DATABASE_URL=sqlite:///./data/sales.db

# Autenticação Basic Auth (obrigatório em produção)
ADMIN_USER=admin
ADMIN_PASS=troque-essa-senha

# CORS — URL do Vercel (separar múltiplas por vírgula)
# Exemplo: ALLOWED_ORIGINS=["https://seu-app.vercel.app","http://localhost:3000"]
ALLOWED_ORIGINS=["http://localhost:3000"]

# Mercado Livre — registre em https://developers.mercadolibre.com.br
MELI_APP_ID=
MELI_SECRET_KEY=
MELI_REDIRECT_URI=http://localhost:8000/auth/mercadolivre/callback

# Shopee — registre em https://open.shopee.com
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_REDIRECT_URI=http://localhost:8000/auth/shopee/callback

# Frontend (desenvolvimento local — em produção usar /api via nginx)
NEXT_PUBLIC_API_BASE=http://localhost:8000
